// ── State ───────────────────────────────────────────────────────────────────

let currentRole = '';
let responses = [];

function loadResponses() {
  try {
    const raw = localStorage.getItem('brgy_survey_responses');
    if (raw) responses = JSON.parse(raw);
  } catch(e) { responses = []; }
}

function saveResponse(entry) {
  loadResponses();
  responses.push(entry);
  localStorage.setItem('brgy_survey_responses', JSON.stringify(responses));
}

// ── Navigation ───────────────────────────────────────────────────────────────

function goTo(screenName) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + screenName).classList.add('active');
  window.scrollTo(0, 0);
}

// ── Role Selection ────────────────────────────────────────────────────────────

function selectRole(role) {
  currentRole = role;
  document.getElementById('official-fields').style.display = role === 'official' ? 'block' : 'none';
  document.getElementById('official-yrs').style.display   = role === 'official' ? 'block' : 'none';
  document.getElementById('resident-fields').style.display = role === 'resident' ? 'block' : 'none';
  document.getElementById('resident-purok').style.display  = role === 'resident' ? 'block' : 'none';
  goTo('profile');
}

// ── Profile Validation ────────────────────────────────────────────────────────

function startSurvey() {
  const age = document.getElementById('p-age').value;
  const sex = document.getElementById('p-sex').value;
  const err = document.getElementById('profile-error');

  let valid = age && sex;
  if (currentRole === 'official') {
    valid = valid && document.getElementById('p-position').value && document.getElementById('p-yrs-service').value;
  } else {
    valid = valid && document.getElementById('p-yrs-res').value;
  }

  if (!valid) { err.classList.add('show'); return; }
  err.classList.remove('show');

  renderQuestions('part1', QUESTIONS[currentRole].part1);
  renderQuestions('part2', QUESTIONS[currentRole].part2);
  document.getElementById('part1-title').textContent = QUESTIONS[currentRole].part1.title;
  document.getElementById('part2-title').textContent = QUESTIONS[currentRole].part2.title;
  goTo('part1');
}

// ── Render Questions ──────────────────────────────────────────────────────────

function renderQuestions(partId, partData) {
  const container = document.getElementById(partId + '-questions');
  container.innerHTML = '';
  const labels = ['SD','D','N','A','SA'];

  partData.items.forEach((q, i) => {
    const qNum = i + 1;
    const card = document.createElement('div');
    card.className = 'question-card';
    card.id = `card-${partId}-${i}`;

    let radios = '';
    for (let v = 5; v >= 1; v--) {
      radios += `
        <div class="likert-option">
          <input type="radio" name="${partId}_q${i}" id="${partId}_q${i}_v${v}" value="${v}" onchange="markAnswered('${partId}',${i})"/>
          <label for="${partId}_q${i}_v${v}">
            <span class="num">${v}</span>
            <span class="abbr">${labels[v-1]}</span>
          </label>
        </div>`;
    }

    card.innerHTML = `
      <div class="question-num">ITEM ${qNum}</div>
      <div class="question-text">${q}</div>
      <div class="likert-row">${radios}</div>`;
    container.appendChild(card);
  });
}

function markAnswered(partId, idx) {
  const card = document.getElementById(`card-${partId}-${idx}`);
  card.classList.add('answered');
  card.classList.remove('unanswered-error');
}

// ── Validation ────────────────────────────────────────────────────────────────

function validatePart(partId, numItems) {
  let allAnswered = true;
  for (let i = 0; i < numItems; i++) {
    const answered = document.querySelector(`input[name="${partId}_q${i}"]:checked`);
    const card = document.getElementById(`card-${partId}-${i}`);
    if (!answered) {
      card.classList.add('unanswered-error');
      allAnswered = false;
    }
  }
  return allAnswered;
}

function nextPart() {
  const n = QUESTIONS[currentRole].part1.items.length;
  const err = document.getElementById('part1-error');
  if (!validatePart('part1', n)) { err.classList.add('show'); return; }
  err.classList.remove('show');
  goTo('part2');
}

// ── Submit ────────────────────────────────────────────────────────────────────

function submitSurvey() {
  const n2 = QUESTIONS[currentRole].part2.items.length;
  const err = document.getElementById('part2-error');
  if (!validatePart('part2', n2)) { err.classList.add('show'); return; }
  err.classList.remove('show');

  const n1 = QUESTIONS[currentRole].part1.items.length;
  const p1scores = [], p2scores = [];

  for (let i = 0; i < n1; i++) {
    p1scores.push(+document.querySelector(`input[name="part1_q${i}"]:checked`).value);
  }
  for (let i = 0; i < n2; i++) {
    p2scores.push(+document.querySelector(`input[name="part2_q${i}"]:checked`).value);
  }

  const wm1 = (p1scores.reduce((a,b)=>a+b,0)/n1).toFixed(2);
  const wm2 = (p2scores.reduce((a,b)=>a+b,0)/n2).toFixed(2);

  const entry = {
    timestamp: new Date().toLocaleString('en-PH'),
    role: currentRole,
    name: document.getElementById('p-name').value || 'Anonymous',
    age: document.getElementById('p-age').value,
    sex: document.getElementById('p-sex').value,
    position: currentRole === 'official' ? document.getElementById('p-position').value : null,
    yrsService: currentRole === 'official' ? document.getElementById('p-yrs-service').value : null,
    yrsRes: currentRole === 'resident' ? document.getElementById('p-yrs-res').value : null,
    purok: currentRole === 'resident' ? document.getElementById('p-purok').value : null,
    part1scores: p1scores,
    part2scores: p2scores,
    wm1, wm2
  };

  saveResponse(entry);
  goTo('thanks');
}

// ── Another Response ──────────────────────────────────────────────────────────

function anotherResponse() {
  currentRole = '';
  document.getElementById('p-name').value = '';
  document.getElementById('p-age').value = '';
  document.getElementById('p-sex').value = '';
  document.getElementById('p-position').value = '';
  document.getElementById('p-yrs-service').value = '';
  document.getElementById('p-yrs-res').value = '';
  document.getElementById('p-purok').value = '';
  goTo('landing');
}

// ── Results Modal ─────────────────────────────────────────────────────────────

function openResults() {
  loadResponses();
  const modal = document.getElementById('results-modal');
  const list = document.getElementById('results-list');
  const count = document.getElementById('results-count');

  const officials = responses.filter(r => r.role === 'official');
  const residents = responses.filter(r => r.role === 'resident');
  count.textContent = `${responses.length} total response(s) — ${officials.length} official(s), ${residents.length} resident(s)`;

  if (responses.length === 0) {
    list.innerHTML = '<div class="empty-state">No responses yet. Share the survey with respondents to start collecting data.</div>';
  } else {
    list.innerHTML = responses.map((r, i) => `
      <div class="response-entry">
        <div class="r-name">${i+1}. ${r.name} &nbsp;<span style="font-weight:400;color:var(--gray)">${r.role === 'official' ? '🏛 Official' : '🏘 Resident'}</span></div>
        <div class="r-meta">${r.timestamp} &nbsp;·&nbsp; ${r.age} yrs, ${r.sex} &nbsp;·&nbsp; ${r.role === 'official' ? r.position + ' · ' + r.yrsService : (r.purok || 'Poblacion 1') + ' · ' + r.yrsRes}</div>
        <div class="r-scores">
          Awareness WM: <strong>${r.wm1}</strong> &nbsp;|&nbsp;
          Implementation WM: <strong>${r.wm2}</strong>
        </div>
      </div>`).join('');
  }

  modal.classList.add('open');
}

function closeResults() {
  document.getElementById('results-modal').classList.remove('open');
}

function clearResults() {
  if (confirm('Are you sure you want to delete all saved responses? This cannot be undone.')) {
    localStorage.removeItem('brgy_survey_responses');
    responses = [];
    closeResults();
  }
}

loadResponses();
</script>
